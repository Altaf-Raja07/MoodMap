# ============================================
# MOODMAP BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!

# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB Configuration
# Get from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb://localhost:27017/moodmap
# For MongoDB Atlas, use: mongodb+srv://username:password@cluster.mongodb.net/moodmap

# JWT Secret (Authentication)
# Generate random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRE=7d

# Places API: Using OpenStreetMap (Overpass + Nominatim)
# No API key required - 100% free, no billing, no sign-up needed

# CORS Origin (Frontend URL)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Cache Settings
CACHE_TTL=3600

# Email Configuration (Optional - for production)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# FROM_EMAIL=noreply@moodmap.com
# FROM_NAME=MoodMap Team
